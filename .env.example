# Copy this file to .env and fill in your values

# Groq API (free at console.groq.com)
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.1-8b-instant
# Other options: llama-3.3-70b-versatile, mixtral-8x7b-32768

# Embedding model (downloaded automatically on first run, ~500MB)
EMBEDDING_MODEL=intfloat/multilingual-e5-base

# Local storage paths (relative to project root)
CHROMA_DB_PATH=./chroma_db
SOURCES_JSON_PATH=./data/sources.json

# RAG settings
TOP_K_RETRIEVAL=5

# Server
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173

# PDF security: comma-separated path prefixes that are allowed to be served
# Set to your PDFs parent folder. Default allows anywhere in C:/Users/
PDF_SERVE_ALLOWED_PATHS=C:/Users/,C:/xerg's/
